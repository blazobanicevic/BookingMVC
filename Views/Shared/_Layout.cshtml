<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BookingMVC</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/BookingMVC.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">BookingMVC</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">

                        <li class="nav-item">
                            <a class="nav-link text-dark"
                               asp-controller="Home"
                               asp-action="Index">
                                Home
                            </a>
                        </li>

                        <li class="nav-item">
                            <form asp-controller="Smjestaj"
                                  asp-action="Search"
                                  method="get"
                                  class="d-flex align-items-center">

                                <div class="input-group">

                                    <input class="form-control"
                                           type="search"
                                           name="search"
                                           placeholder="Naziv smještaja ili grad..." />

                                    <button class="btn btn-outline-primary" type="submit">
                                        <i class="bi bi-search"></i>
                                    </button>

                                </div>

                            </form>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link text-dark"
                               asp-controller="Smjestaj"
                               asp-action="AdvancedSearch">
                                Detaljna pretraga
                            </a>
                        </li>

                        @if (Context.Session.GetString("Uloga") == "Admin")
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark"
                                   asp-controller="Smjestaj"
                                   asp-action="Index">
                                    Smještaji
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link text-dark"
                                   href="#">
                                    Rezervacije
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link text-dark"
                                   href="#">
                                    Recenzije
                                </a>
                            </li>
                        }

                        @if (Context.Session.GetString("Uloga") == "Korisnik")
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark"
                                   href="#">
                                    Lista želja
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link text-dark"
                                   href="#">
                                    Rezervacije
                                </a>
                            </li>
                        }

                    </ul>

                    <ul class="navbar-nav">
                        @if (Context.Session.GetInt32("IdKorisnik") != null)
                        {
                            <li class="nav-item">
                                <span class="nav-link text-dark">
                                    @Context.Session.GetString("Ime") (@Context.Session.GetString("Uloga"))
                                </span>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Auth" asp-action="Logout">Logout</a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Auth" asp-action="Login">Login</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - BookingMVC
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
