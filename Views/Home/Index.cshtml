@{
    ViewData["Title"] = "Početna";
}

<section class="landing-hero">

    <div class="landing-topbar">
        <div class="landing-logo">
            <i class="bi bi-house-door"></i>
            <span>BookingMVC</span>
        </div>

        <div class="landing-actions">
            <a asp-controller="Auth"
               asp-action="Login"
               class="landing-btn landing-btn-outline">
                <i class="bi bi-box-arrow-in-right"></i>
                Prijava
            </a>

            <a asp-controller="Auth"
               asp-action="Register"
               class="landing-btn landing-btn-primary">
                <i class="bi bi-person"></i>
                Registracija
            </a>
        </div>
    </div>

    <div class="landing-content">
        <h1>
            Pronađi savršen<br/>
            <span>smještaj za svoj odmor</span>
        </h1>

        <p>
            Otkrijte provjerene smještaje širom Crne Gore.
            <br />
            Rezervišite brzo i bez komplikacija.
        </p>
    </div>

</section>