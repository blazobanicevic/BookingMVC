@model List<BookingMVC.Models.Recenzija>

@{
    ViewData["Title"] = "Recenzije";
}

<div class="search-results-page">

    <div class="results-hero">
        <h1>Recenzije</h1>
        <p>Pregled svih recenzija ostavljenih za smještaje.</p>
    </div>

    @if (!Model.Any())
    {
        <div class="no-results">
            <h3>Nema recenzija</h3>
            <p>Još uvijek nije ostavljena nijedna recenzija.</p>
        </div>
    }
    else
    {
        <div class="reviews-grid">

            @foreach (var recenzija in Model)
            {
                <a class="review-box review-link"
                   asp-controller="Smjestaj"
                   asp-action="Details"
                   asp-route-id="@recenzija.IdSmjestaj">

                    <div class="review-top">

                        <div>
                            <h3>@recenzija.Smjestaj.Naziv</h3>
                            <span>@recenzija.Smjestaj.Grad.Naziv</span>
                        </div>

                        <div class="review-stars-big">
                            @for (int i = 1; i <= 5; i++)
                            {
                                if (i <= recenzija.Ocjena)
                                {
                                    <span class="star-filled">★</span>
                                }
                                else
                                {
                                    <span class="star-empty">★</span>
                                }
                            }
                        </div>

                    </div>

                    <div class="review-user">
                        👤 @recenzija.Korisnik.Ime @recenzija.Korisnik.Prezime
                    </div>

                    <p class="review-text">
                        @recenzija.Komentar
                    </p>

                </a>
            }

        </div>
    }

</div>