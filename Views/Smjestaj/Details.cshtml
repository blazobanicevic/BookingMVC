@model BookingMVC.Models.Smjestaj

@{
    ViewData["Title"] = "Detalji smještaja";
    var uloga = Context.Session.GetString("Uloga");
    bool uListiZelja = (bool)(ViewBag.UListiZelja ?? false);
}

<h2>@Model.Naziv</h2>

<p><strong>Opis:</strong> @(string.IsNullOrWhiteSpace(Model.Opis) ? "-" : Model.Opis)</p>
<p><strong>Grad:</strong> @Model.Grad.Naziv</p>
<p><strong>Adresa:</strong> @Model.Adresa</p>
<p><strong>Tip:</strong> @Model.TipSmjestaja.Naziv</p>
<p><strong>Broj osoba:</strong> @Model.BrojOsoba</p>
<p><strong>Cijena:</strong> @Model.CijenaPoNoci € / noć</p>
<p><strong>Izdavalac:</strong> @Model.Admin.Ime @Model.Admin.Prezime</p>

@if (TempData["ReservationSuccess"] != null)
{
    <div class="alert alert-success">
        @TempData["ReservationSuccess"]
    </div>
}

@if (TempData["ReservationError"] != null)
{
    <div class="alert alert-danger">
        @TempData["ReservationError"]
    </div>
}

@if (uloga == "Korisnik")
{
    <hr />

    @if (uListiZelja)
    {
        <a asp-controller="ListaZelja"
           asp-action="Toggle"
           asp-route-idSmjestaj="@Model.IdSmjestaj"
           class="btn btn-danger">
            Ukloni iz liste želja
        </a>
    }
    else
    {
        <a asp-controller="ListaZelja"
           asp-action="Toggle"
           asp-route-idSmjestaj="@Model.IdSmjestaj"
           class="btn btn-outline-danger">
            Dodaj u listu želja
        </a>
    }

    <button type="button" class="btn btn-primary" onclick="openReservationModal()">
        Rezerviši
    </button>

    <a href="#" onclick="openMessagesWith(@Model.IdAdmin); return false;" class="btn btn-outline-secondary"> Pošalji poruku izdavaocu</a>
}

<hr />

<h3>Recenzije</h3>

@if (TempData["ReviewSuccess"] != null)
{
    <div class="alert alert-success">
        @TempData["ReviewSuccess"]
    </div>
}

@if (TempData["ReviewError"] != null)
{
    <div class="alert alert-danger">
        @TempData["ReviewError"]
    </div>
}

@{
    var recenzije = ViewBag.Recenzije as List<BookingMVC.Models.Recenzija>;
    bool mozeOstavitiRecenziju = (bool)(ViewBag.MozeOstavitiRecenziju ?? false);
    bool vecOstavioRecenziju = (bool)(ViewBag.VecOstavioRecenziju ?? false);
}

@if (uloga == "Korisnik" && mozeOstavitiRecenziju && !vecOstavioRecenziju)
{
    <form asp-controller="Recenzija" asp-action="Create" method="post">
        <input type="hidden" name="idSmjestaj" value="@Model.IdSmjestaj" />

        <div class="mb-3">
            <label>Ocjena</label>
            <select name="ocjena" class="form-select" required>
                <option value="5">5 - Odlično</option>
                <option value="4">4 - Vrlo dobro</option>
                <option value="3">3 - Dobro</option>
                <option value="2">2 - Loše</option>
                <option value="1">1 - Veoma loše</option>
            </select>
        </div>

        <div class="mb-3">
            <label>Komentar</label>
            <textarea name="komentar" class="form-control" required></textarea>
        </div>

        <button class="btn btn-primary">Ostavi recenziju</button>
    </form>
}

@if (recenzije == null || !recenzije.Any())
{
    <p>Nema recenzija za ovaj smještaj.</p>
}
else
{
    <div class="review-card">

        @for (int i = 0; i < recenzije.Count; i++)
        {
            var r = recenzije[i];

            <div class="review-item">
                <div class="review-header">
                    <strong>@r.Korisnik.Ime @r.Korisnik.Prezime</strong>

                    <div class="review-stars">
                        @for (int j = 0; j < r.Ocjena; j++)
                        {
                            <span>★</span>
                        }

                        @for (int j = r.Ocjena; j < 5; j++)
                        {
                            <span class="review-star-empty">★</span>
                        }
                    </div>
                </div>

                <p class="review-comment">@r.Komentar</p>
            </div>

            @if (i != recenzije.Count - 1)
            {
                <hr class="review-divider" />
            }
        }

    </div>
}

@if (uloga == "Korisnik")
{
    <div id="reservationBackdrop" class="reservation-backdrop d-none">
        <div class="reservation-modal">
            <div class="reservation-header">
                <div>
                    <span class="reservation-kicker">Rezervacija</span>
                    <h2>@Model.Naziv</h2>
                    <p>@Model.CijenaPoNoci € po noći</p>
                </div>

                <button type="button" class="reservation-close" onclick="closeReservationModal()">
                    X
                </button>
            </div>

            <form asp-controller="Rezervacija" asp-action="Create" method="post">
                <input type="hidden" name="idSmjestaj" value="@Model.IdSmjestaj" />
                <input type="hidden" name="brojOsoba" value="@Model.BrojOsoba" />

                <div class="reservation-field">
                    <span>Datum prijave</span>
                    <input id="datumPrijave" name="datumPrijave" type="date" onchange="calculateReservation()" required />
                </div>

                <div class="reservation-field">
                    <span>Datum odjave</span>
                    <input id="datumOdjave" name="datumOdjave" type="date" onchange="calculateReservation()" required />
                </div>

                <div class="reservation-availability">
                    <h5>Dostupnost</h5>

                    <div class="reservation-calendar-header">
                        <button type="button" onclick="changeAvailabilityMonth(-1)">‹</button>
                        <span id="availabilityMonthTitle"></span>
                        <button type="button" onclick="changeAvailabilityMonth(1)">›</button>
                    </div>

                    <div id="availabilityCalendar" class="reservation-calendar"></div>

                    <div class="reservation-legend">
                        <span class="free-box"></span> Slobodno
                        <span class="pending-box"></span> Na čekanju
                        <span class="busy-box"></span> Zauzeto
                    </div>
                </div>

                <div class="reservation-summary">
                    <p><strong>Broj osoba:</strong> @Model.BrojOsoba</p>
                    <p><strong>Broj noćenja:</strong> <span id="brojNocenja">0</span></p>
                    <p><strong>Ukupno:</strong> <span id="ukupnaCijena">0</span> €</p>
                </div>

                <p id="reservationError" class="reservation-error d-none">
                    Datum odjave mora biti poslije datuma prijave.
                </p>

                <button id="confirmReservationButton" type="submit" class="reservation-submit" disabled>
                    Potvrdi rezervaciju
                </button>
            </form>
        </div>
    </div>
}

<script>
    let availabilityMonth = new Date().getMonth() + 1;
    let availabilityYear = new Date().getFullYear();

    function loadAvailabilityCalendar() {
        fetch(`/Rezervacija/Availability?idSmjestaj=@Model.IdSmjestaj&mjesec=${availabilityMonth}&godina=${availabilityYear}`)
            .then(response => response.json())
            .then(days => {
                const calendar = document.getElementById("availabilityCalendar");
                const title = document.getElementById("availabilityMonthTitle");

                calendar.innerHTML = "";

                const monthName = new Date(availabilityYear, availabilityMonth - 1)
                    .toLocaleString("default", { month: "long" });

                title.innerText = `${monthName} ${availabilityYear}`;

                days.forEach(day => {
                    const cell = document.createElement("div");
                    cell.classList.add("reservation-day");

                    if (day.status === "slobodno") {
                        cell.classList.add("free-day");
                    }

                    if (day.status === "naCekanju") {
                        cell.classList.add("pending-day");
                    }

                    if (day.status === "zauzeto") {
                        cell.classList.add("busy-day");
                    }

                    cell.innerText = day.dan;
                    calendar.appendChild(cell);
                });
            });
    }

    function changeAvailabilityMonth(change) {
        availabilityMonth += change;

        if (availabilityMonth < 1) {
            availabilityMonth = 12;
            availabilityYear--;
        }

        if (availabilityMonth > 12) {
            availabilityMonth = 1;
            availabilityYear++;
        }

        loadAvailabilityCalendar();
    }

    const cijenaPoNoci = @Model.CijenaPoNoci.ToString(System.Globalization.CultureInfo.InvariantCulture);

    function openReservationModal() {
        document.getElementById("reservationBackdrop").classList.remove("d-none");
        loadAvailabilityCalendar();
    }

    function closeReservationModal() {
        document.getElementById("reservationBackdrop").classList.add("d-none");
    }

    function calculateReservation() {
        const prijava = document.getElementById("datumPrijave").value;
        const odjava = document.getElementById("datumOdjave").value;
        const error = document.getElementById("reservationError");
        const button = document.getElementById("confirmReservationButton");

        if (!prijava || !odjava) {
            button.disabled = true;
            return;
        }

        const start = new Date(prijava);
        const end = new Date(odjava);
        const diffTime = end - start;
        const diffDays = diffTime / (1000 * 60 * 60 * 24);

        if (diffDays <= 0) {
            error.classList.remove("d-none");
            button.disabled = true;
            document.getElementById("brojNocenja").innerText = "0";
            document.getElementById("ukupnaCijena").innerText = "0";
            return;
        }

        error.classList.add("d-none");
        button.disabled = false;

        document.getElementById("brojNocenja").innerText = diffDays;
        document.getElementById("ukupnaCijena").innerText = (diffDays * cijenaPoNoci).toFixed(2);
    }
</script>