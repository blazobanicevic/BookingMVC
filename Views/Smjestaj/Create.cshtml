@model BookingMVC.Models.Smjestaj

@{
    ViewData["Title"] = "Dodaj smještaj";
}

<div class="place-form-page">

    <div class="results-hero">
        <h1>Dodaj smještaj</h1>
        <p>Unesi osnovne podatke o smještaju koji želiš da ponudiš korisnicima.</p>
    </div>

    <div class="place-form-card">

        <form asp-action="Create" method="post">

            <div class="place-form-grid">

                <div class="place-field">
                    <label>Naziv</label>
                    <input asp-for="Naziv" placeholder="Npr. Apartman Lux" />
                </div>

                <div class="place-field">
                    <label>Grad</label>
                    <input type="text" name="gradNaziv" placeholder="Npr. Budva" />
                </div>

                <div class="place-field full">
                    <label>Opis</label>
                    <textarea asp-for="Opis" placeholder="Kratak opis smještaja..."></textarea>
                </div>

                <div class="place-field">
                    <label>Adresa</label>
                    <input asp-for="Adresa" placeholder="Unesi adresu" />
                </div>

                <div class="place-field">
                    <label>Tip smještaja</label>
                    <select asp-for="IdTip">
                        @foreach (var tip in ViewBag.Tipovi)
                        {
                            <option value="@tip.IdTipSmjestaja">@tip.Naziv</option>
                        }
                    </select>
                </div>

                <div class="place-field">
                    <label>Broj osoba</label>
                    <input asp-for="BrojOsoba" type="number" min="1" placeholder="Npr. 2" />
                </div>

                <div class="place-field">
                    <label>Cijena po noći</label>
                    <input asp-for="CijenaPoNoci" type="number" step="0.01" min="0" placeholder="Npr. 50.00" />
                </div>

            </div>

            <div class="place-form-actions">
                <button type="submit">
                    Sačuvaj smještaj
                </button>

                <a asp-controller="Smjestaj" asp-action="Index">
                    Nazad na smještaje
                </a>
            </div>

        </form>

    </div>

</div>