@model List<BookingMVC.Models.Smjestaj>

@{
    ViewData["Title"] = "Smještaji";
}

<div class="search-results-page">

    <div class="results-hero">
        <h1>Moji smještaji</h1>
        <p>Pregled svih smještaja koje si dodao u sistem.</p>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success mb-4">
            @TempData["Success"]
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger mb-4">
            @TempData["Error"]
        </div>
    }

    <div class="place-toolbar">
        <a asp-action="Create" class="place-add-btn">
            + Dodaj smještaj
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="no-results">
            <h3>Nema smještaja</h3>
            <p>Još uvijek nisi dodao nijedan smještaj.</p>
        </div>
    }
    else
    {
        <div class="offers-grid">

            @foreach (var smjestaj in Model)
            {
                <div class="offer-card">

                    <div class="offer-image">
                        🏨
                    </div>

                    <div class="offer-content">

                        <div class="place-card-header">

                            <div>
                                <h3>@smjestaj.Naziv</h3>

                                <p class="offer-location">
                                    📍 @smjestaj.Grad.Naziv
                                </p>
                            </div>

                            @if (smjestaj.Aktivan)
                            {
                                <span class="place-status active">
                                    Aktivan
                                </span>
                            }
                            else
                            {
                                <span class="place-status inactive">
                                    Neaktivan
                                </span>
                            }

                    </div>

                    <p class="offer-description">
                        @(string.IsNullOrWhiteSpace(smjestaj.Opis)
                                            ? "Opis nije dostupan."
                                            : smjestaj.Opis)
                </p>

                        <div class="offer-details">

                            <div>
                                <strong>Tip</strong>
                                <span>@smjestaj.TipSmjestaja.Naziv</span>
                            </div>

                            <div>
                                <strong>Osoba</strong>
                                <span>@smjestaj.BrojOsoba</span>
                            </div>

                        </div>

                        <div class="offer-bottom">

                            <div>
                                <strong class="price">
                                    @smjestaj.CijenaPoNoci €
                                </strong>
                                <small>/ noć</small>
                            </div>

                            <div class="place-actions">

                                <a asp-action="Edit"
                                   asp-route-id="@smjestaj.IdSmjestaj"
                                   class="edit-btn">
                                    Uredi
                                </a>

                                <a asp-action="Delete"
                                   asp-route-id="@smjestaj.IdSmjestaj"
                                   class="delete-btn"
                                   onclick="return confirm('Da li ste sigurni da želite obrisati ovaj smještaj?');">
                                    Obriši
                                </a>

                            </div>

                        </div>

                    </div>

                </div>
                }

        </div>
    }

</div>