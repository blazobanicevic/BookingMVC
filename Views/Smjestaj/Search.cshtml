@model List<BookingMVC.Models.Smjestaj>

@{
    ViewData["Title"] = "Rezultati pretrage";
}

<div class="search-results-page">

    <div class="results-hero">
        <h1>Rezultati pretrage</h1>

        <p>
            Pronađeno <strong>@Model.Count</strong>
            @(Model.Count == 1 ? "smještaj" : "smještaja")
        </p>
    </div>

    @if (!Model.Any())
    {
        <div class="no-results">
            <h3>Nema rezultata</h3>
            <p>Nijedan smještaj ne odgovara zadatim kriterijumima.</p>

            <a asp-controller="Smjestaj"
               asp-action="AdvancedSearch"
               class="btn-back">
                Nazad na pretragu
            </a>
        </div>
    }
    else
    {
        <div class="offers-grid">

            @foreach (var smjestaj in Model)
            {
                <div class="offer-card">

                    <div class="offer-image">
                        🏨
                    </div>

                    <div class="offer-content">

                        <h3>@smjestaj.Naziv</h3>

                        <p class="offer-location">
                            📍 @smjestaj.Grad.Naziv
                        </p>

                        <p class="offer-description">
                            @(string.IsNullOrWhiteSpace(smjestaj.Opis)
                                                ? "Opis nije dostupan."
                                                : smjestaj.Opis)
                </p>

                        <div class="offer-details">

                            <div>
                                <strong>Tip</strong>
                                <span>@smjestaj.TipSmjestaja.Naziv</span>
                            </div>

                            <div>
                                <strong>Osoba</strong>
                                <span>@smjestaj.BrojOsoba</span>
                            </div>

                        </div>

                        <div class="offer-bottom">

                            <div>
                                <strong class="price">
                                    @smjestaj.CijenaPoNoci €
                                </strong>

                                <small>/ noć</small>
                            </div>

                            <a asp-controller="Smjestaj"
                               asp-action="Details"
                               asp-route-id="@smjestaj.IdSmjestaj"
                               class="details-btn">
                                Detalji
                            </a>

                        </div>

                    </div>

                </div>
                }

        </div>
    }

</div>