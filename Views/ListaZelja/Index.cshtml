@model List<BookingMVC.Models.ListaZelja>

@{
    ViewData["Title"] = "Lista želja";
}

<div class="search-results-page">

    <div class="results-hero">
        <h1>Moja lista želja</h1>
        <p>Smještaji koje si sačuvao/la za kasnije.</p>
    </div>

    @if (!Model.Any())
    {
        <div class="no-results">
            <h3>Lista želja je prazna</h3>
            <p>Trenutno nemaš nijedan smještaj u listi želja.</p>

            <a asp-controller="Smjestaj"
               asp-action="AdvancedSearch"
               class="btn-back">
                Pronađi smještaj
            </a>
        </div>
    }
    else
    {
        <div class="offers-grid">
            @foreach (var stavka in Model)
            {
                <div class="offer-card">

                    <div class="offer-image">
                        ❤️
                    </div>

                    <div class="offer-content">
                        <h3>@stavka.Smjestaj.Naziv</h3>

                        <p class="offer-location">
                            📍 @stavka.Smjestaj.Grad.Naziv
                        </p>

                        <p class="offer-description">
                            @(string.IsNullOrWhiteSpace(stavka.Smjestaj.Opis)
                                                ? "Opis nije dostupan."
                                                : stavka.Smjestaj.Opis)
                </p>

                        <div class="offer-details">
                            <div>
                                <strong>Tip</strong>
                                <span>@stavka.Smjestaj.TipSmjestaja.Naziv</span>
                            </div>

                            <div>
                                <strong>Osoba</strong>
                                <span>@stavka.Smjestaj.BrojOsoba</span>
                            </div>
                        </div>

                        <div class="offer-bottom">
                            <div>
                                <strong class="price">
                                    @stavka.Smjestaj.CijenaPoNoci €
                                </strong>
                                <small>/ noć</small>
                            </div>

                            <div class="wishlist-actions">
                                <a asp-controller="Smjestaj"
                                   asp-action="Details"
                                   asp-route-id="@stavka.Smjestaj.IdSmjestaj"
                                   class="details-btn">
                                    Detalji
                                </a>

                                <a asp-action="Remove"
                                   asp-route-id="@stavka.IdListaZelja"
                                   class="remove-btn">
                                    Ukloni
                                </a>
                            </div>
                        </div>
                    </div>

                </div>
                }
        </div>
    }

</div>