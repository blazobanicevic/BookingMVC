@model List<BookingMVC.Models.Rezervacija>

@{
    ViewData["Title"] = "Rezervacije";
    var uloga = Context.Session.GetString("Uloga");

    var rezervacijeNaCekanju = Model.Where(r => r.IdStatus == 1).ToList();
    var sveRezervacijeSortirane = Model
        .OrderBy(r => r.IdStatus == 1 ? 0 : 1)
        .ThenBy(r => r.DatumPrijave)
        .ToList();
}

<div class="reservations-page">

    <div class="reservations-hero">
        <div class="reservations-hero-icon">📅</div>
        <div>
            <h1>Rezervacije</h1>
            <p>
                @(uloga == "Admin"
                                ? "Pregled i upravljanje rezervacijama."
                                : "Pregled tvojih rezervacija.")
            </p>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="no-results">
            <h3>Nema rezervacija</h3>
            <p>Nema rezervacija za prikaz.</p>
        </div>
    }
    else
    {
        @if (uloga == "Admin" && rezervacijeNaCekanju.Any())
        {
            <section class="reservation-section">
                <div class="reservation-section-header">
                    <div>
                        <h2>📅 Na čekanju <span>@rezervacijeNaCekanju.Count</span></h2>
                        <p>Rezervacije koje trebaju vašu potvrdu.</p>
                    </div>
                </div>

                <div class="pending-reservation-grid">
                    @foreach (var r in rezervacijeNaCekanju)
                    {
                        <div class="pending-reservation-card">
                            <div class="pending-card-top">
                                <div>
                                    <h3>@r.Smjestaj.Naziv</h3>
                                    <p>📍 @r.Smjestaj.Grad.Naziv</p>
                                </div>

                                <span class="reservation-status status-@r.IdStatus">
                                    @r.StatusRezervacije.Naziv
                                </span>
                            </div>

                            <div class="pending-card-info">
                                <div>
                                    <strong>Korisnik</strong>
                                    <span>@r.Korisnik.Ime @r.Korisnik.Prezime</span>
                                </div>

                                <div>
                                    <strong>Prijava</strong>
                                    <span>@r.DatumPrijave.ToString("dd.MM.yyyy")</span>
                                </div>

                                <div>
                                    <strong>Odjava</strong>
                                    <span>@r.DatumOdjave.ToString("dd.MM.yyyy")</span>
                                </div>

                                <div>
                                    <strong>Osoba</strong>
                                    <span>@r.BrojOsoba</span>
                                </div>
                            </div>

                            <div class="pending-card-actions">
                                <form asp-action="Confirm" method="post">
                                    <input type="hidden" name="idRezervacija" value="@r.IdRezervacija" />
                                    <button class="reservation-btn confirm">Potvrdi</button>
                                </form>

                                <form asp-action="Reject" method="post">
                                    <input type="hidden" name="idRezervacija" value="@r.IdRezervacija" />
                                    <button class="reservation-btn reject">Odbij</button>
                                </form>
                            </div>
                        </div>
                    }
                </div>
            </section>
        }

        <section class="reservation-section">
            <div class="reservation-section-header">
                <div>
                    <h2>📅 Sve rezervacije</h2>
                    <p>Sve vaše rezervacije.</p>
                </div>
            </div>

            <div class="reservation-compact-list">
                @foreach (var r in sveRezervacijeSortirane)
                {
                    <div class="reservation-compact-card">

                        <div class="reservation-place">
                            <h3>@r.Smjestaj.Naziv</h3>
                            <p>@r.Smjestaj.Grad.Naziv</p>
                        </div>

                        <div class="reservation-compact-info">
                            <div>
                                <strong>@(uloga == "Admin" ? "Korisnik" : "Izdavalac")</strong>
                                <span>
                                    @if (uloga == "Admin")
                                    {
                                        @($"{r.Korisnik.Ime} {r.Korisnik.Prezime}")
                                    }
                                    else
                                    {
                                        @($"{r.Smjestaj.Admin.Ime} {r.Smjestaj.Admin.Prezime}")
                                    }
                                </span>
                            </div>

                            <div>
                                <strong>Prijava</strong>
                                <span>@r.DatumPrijave.ToString("dd.MM.yyyy")</span>
                            </div>

                            <div>
                                <strong>Odjava</strong>
                                <span>@r.DatumOdjave.ToString("dd.MM.yyyy")</span>
                            </div>

                            <div>
                                <strong>Osoba</strong>
                                <span>@r.BrojOsoba</span>
                            </div>
                        </div>

                        <div class="reservation-right">
                            <span class="reservation-status status-@r.IdStatus">
                                @r.StatusRezervacije.Naziv
                            </span>

                            @if (uloga == "Korisnik")
                            {
                                <form asp-action="Cancel"
                                      method="post"
                                      onsubmit="return confirm('Da li ste sigurni da želite da otkažete ovu rezervaciju?');">

                                    <input type="hidden" name="idRezervacija" value="@r.IdRezervacija" />
                                    <button class="reservation-btn cancel">Otkaži</button>
                                </form>
                            }
                        </div>

                    </div>
                }
            </div>
        </section>
    }

    @if (uloga == "Admin")
    {
        var smjestajiAdmina = ViewBag.SmjestajiAdmina as List<BookingMVC.Models.Smjestaj>;
        var zauzetiTermini = ViewBag.ZauzetiTermini as List<BookingMVC.Models.Rezervacija>;

        int mjesec = ViewBag.Mjesec;
        int godina = ViewBag.Godina;
        int daniUMjesecu = ViewBag.DaniUMjesecu;

        var prethodniMjesec = mjesec == 1 ? 12 : mjesec - 1;
        var prethodnaGodina = mjesec == 1 ? godina - 1 : godina;

        var sljedeciMjesec = mjesec == 12 ? 1 : mjesec + 1;
        var sljedecaGodina = mjesec == 12 ? godina + 1 : godina;

        <section class="admin-calendar-section">

            <div class="calendar-header-box">
                <div>
                    <h2>Kalendar dostupnosti smještaja</h2>
                    <p>Pregled zauzetih termina po smještajima.</p>
                </div>

                <div class="calendar-navigation">
                    <a asp-action="Index"
                       asp-route-mjesec="@prethodniMjesec"
                       asp-route-godina="@prethodnaGodina">
                        ← Prethodni
                    </a>

                    <strong>
                        @System.Globalization.CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(mjesec).ToUpper()
                        @godina
                    </strong>

                    <a asp-action="Index"
                       asp-route-mjesec="@sljedeciMjesec"
                       asp-route-godina="@sljedecaGodina">
                        Sljedeći →
                    </a>
                </div>
            </div>

            <div class="calendar-table-wrapper">
                <table class="table availability-calendar">
                    <thead>
                        <tr>
                            <th>Smještaj</th>

                            @for (int dan = 1; dan <= daniUMjesecu; dan++)
                            {
                                <th>@dan</th>
                            }
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var smjestaj in smjestajiAdmina)
                        {
                            <tr>
                                <td class="calendar-place">
                                    <strong>@smjestaj.Naziv</strong>
                                    <small>@smjestaj.Grad.Naziv</small>
                                </td>

                                @for (int dan = 1; dan <= daniUMjesecu; dan++)
                                {
                                    var datum = new DateTime(godina, mjesec, dan);

                                    var rezervacijaDana = zauzetiTermini.FirstOrDefault(r =>
                                    r.IdSmjestaj == smjestaj.IdSmjestaj &&
                                    datum >= r.DatumPrijave.Date &&
                                    datum < r.DatumOdjave.Date);

                                    string cssKlasa = "";

                                    if (rezervacijaDana != null)
                                    {
                                        if (rezervacijaDana.IdStatus == 1)
                                        {
                                            cssKlasa = "pending-day";
                                        }
                                        else if (rezervacijaDana.IdStatus == 2)
                                        {
                                            cssKlasa = "confirmed-day";
                                        }
                                    }

                                    <td class="@cssKlasa"></td>
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="calendar-legend">
                <span class="legend-box pending-day"></span> Na čekanju
                <span class="legend-box confirmed-day"></span> Potvrđeno
            </div>

        </section>
    }

</div>